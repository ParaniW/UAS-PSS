{
  "info": {
    "name": "Bengkel Koding Clinic API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Postman collection untuk testing API Laravel klinik: register, login, profile, dan resource dokter/poli/obat/pasien."
  },
  "item": [
    {
      "name": "Register Pasien",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"nama\": \"Pasien Baru\",\n  \"email\": \"pasienbaru@example.com\",\n  \"password\": \"password123\",\n  \"alamat\": \"Jakarta\",\n  \"no_ktp\": \"1234567890123456\",\n  \"no_hp\": \"081234567890\"\n}"
        },
        "url": {
          "raw": "http://127.0.0.1:8000/api/register",
          "protocol": "http",
          "host": ["127","0","0","1"],
          "port": "8000",
          "path": ["api","register"]
        }
      }
    },
    {
      "name": "Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"admin@gmail.com\",\n  \"password\": \"admin123\"\n}"
        },
        "url": {
          "raw": "http://127.0.0.1:8000/api/login",
          "protocol": "http",
          "host": ["127","0","0","1"],
          "port": "8000",
          "path": ["api","login"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const json = pm.response.json();",
              "if (json && json.token) {",
              "  pm.collectionVariables.set('api_token', json.token);",
              "  console.log('api_token set');",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Me (Profile)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{api_token}}"
          }
        ],
        "url": {
          "raw": "http://127.0.0.1:8000/api/me",
          "protocol": "http",
          "host": ["127","0","0","1"],
          "port": "8000",
          "path": ["api","me"]
        }
      }
    },
    {
      "name": "List Dokter",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{api_token}}"
          }
        ],
        "url": {
          "raw": "http://127.0.0.1:8000/api/dokter?per_page=10",
          "protocol": "http",
          "host": ["127","0","0","1"],
          "port": "8000",
          "path": ["api","dokter"],
          "query": [
            {
              "key": "per_page",
              "value": "10"
            }
          ]
        }
      }
    },
    {
      "name": "Create Dokter",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{api_token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"nama\": \"Dokter Baru\",\n  \"email\": \"dokterbaru@example.com\",\n  \"password\": \"dokter123\",\n  \"no_hp\": \"081234567891\",\n  \"alamat\": \"Bandung\",\n  \"id_poli\": 1\n}"
        },
        "url": {
          "raw": "http://127.0.0.1:8000/api/dokter",
          "protocol": "http",
          "host": ["127","0","0","1"],
          "port": "8000",
          "path": ["api","dokter"]
        }
      }
    }
    ,
    {
      "name": "Logout",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{api_token}}" }
        ],
        "url": { "raw": "http://127.0.0.1:8000/api/logout", "protocol": "http", "host": ["127","0","0","1"], "port": "8000", "path": ["api","logout"] }
      }
    },
    {
      "name": "List Pasien",
      "request": {
        "method": "GET",
        "header": [ { "key": "Authorization", "value": "Bearer {{api_token}}" } ],
        "url": { "raw": "http://127.0.0.1:8000/api/pasien?per_page=10", "protocol": "http", "host": ["127","0","0","1"], "port": "8000", "path": ["api","pasien"], "query": [ { "key": "per_page", "value": "10" } ] }
      }
    },
    {
      "name": "Create Pasien",
      "request": {
        "method": "POST",
        "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{api_token}}" } ],
        "body": { "mode": "raw", "raw": "{\n  \"nama\": \"Pasien dari Postman\",\n  \"email\": \"pasien.postman@example.com\",\n  \"password\": \"password123\"\n}" },
        "url": { "raw": "http://127.0.0.1:8000/api/pasien", "protocol": "http", "host": ["127","0","0","1"], "port": "8000", "path": ["api","pasien"] }
      }
    },
    {
      "name": "List Poli",
      "request": {
        "method": "GET",
        "header": [ { "key": "Authorization", "value": "Bearer {{api_token}}" } ],
        "url": { "raw": "http://127.0.0.1:8000/api/poli?per_page=10", "protocol": "http", "host": ["127","0","0","1"], "port": "8000", "path": ["api","poli"], "query": [ { "key": "per_page", "value": "10" } ] }
      }
    },
    {
      "name": "Create Poli",
      "request": {
        "method": "POST",
        "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{api_token}}" } ],
        "body": { "mode": "raw", "raw": "{\n  \"nama_poli\": \"Poli Postman\",\n  \"keterangan\": \"Dibuat via Postman\",\n  \"tarif\": 90000\n}" },
        "url": { "raw": "http://127.0.0.1:8000/api/poli", "protocol": "http", "host": ["127","0","0","1"], "port": "8000", "path": ["api","poli"] }
      }
    },
    {
      "name": "List Obat",
      "request": {
        "method": "GET",
        "header": [ { "key": "Authorization", "value": "Bearer {{api_token}}" } ],
        "url": { "raw": "http://127.0.0.1:8000/api/obat?per_page=10", "protocol": "http", "host": ["127","0","0","1"], "port": "8000", "path": ["api","obat"], "query": [ { "key": "per_page", "value": "10" } ] }
      }
    },
    {
      "name": "Create Obat",
      "request": {
        "method": "POST",
        "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{api_token}}" } ],
        "body": { "mode": "raw", "raw": "{\n  \"nama_obat\": \"Obat Postman\",\n  \"kemasan\": \"Box\",\n  \"harga\": 15000,\n  \"stok\": 50\n}" },
        "url": { "raw": "http://127.0.0.1:8000/api/obat", "protocol": "http", "host": ["127","0","0","1"], "port": "8000", "path": ["api","obat"] }
      }
    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "exec": [],
        "type": "text/javascript"
      }
    },
    {
      "listen": "test",
      "script": {
        "exec": [],
        "type": "text/javascript"
      }
    }
  ],
  "variable": [
    {
      "key": "api_token",
      "value": ""
    }
  ]
}
